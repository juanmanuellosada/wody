# URL de conexión principal a la base de datos (branch de producción/desarrollo en Neon).
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# URL de la shadow database para `prisma migrate dev` (branch dedicado en Neon, distinto del principal).
# Crear un branch separado en Neon, copiar su connection string aquí.
# Solo necesaria para correr migraciones en desarrollo local; no se usa en producción.
SHADOW_DATABASE_URL="postgresql://user:password@shadow-host/dbname?sslmode=require"

AUTH_SECRET="your-auth-secret"
NEXT_PUBLIC_VAPID_PUBLIC_KEY="your-vapid-public-key"
VAPID_PRIVATE_KEY="your-vapid-private-key"
VAPID_SUBJECT="mailto:you@example.com"
CRON_SECRET="your-cron-secret"
CHECKIN_TOKEN_SECRET="your-checkin-token-secret"

# ── Email (Resend) ─────────────────────────────────────────────────────────────

# API key de Resend. Obtenerla en resend.com → API Keys. Formato: re_xxx...
RESEND_API_KEY="re_xxx_replace_me"

# Remitente de todos los mails transaccionales. Requiere dominio verificado en Resend.
EMAIL_FROM="Wody <noreply@wody.com.ar>"

# (Opcional) Si está seteada, los mails incluyen un header Reply-To con esta dirección.
# Útil para que las respuestas de los alumnos lleguen a un inbox monitoreado.
EMAIL_REPLY_TO=""

# Destinatario de las alertas automáticas de cuota (80 % y 95 % del límite mensual).
EMAIL_QUOTA_ALERT_TO="you@example.com"

# Límite mensual de envíos. Free tier de Resend: 3000. Cambiar si se upgradea el plan.
EMAIL_QUOTA_MONTHLY_LIMIT=3000

# URL base de la app, sin slash final. Se usa para construir los links de activación y reset.
APP_URL="https://wody.com.ar"
