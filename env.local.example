# ─────────────────────────────────────────────────────────
# WODY — Variables de entorno requeridas
# Copiá este archivo a .env.local y completá los valores.
# NUNCA subas .env.local al repositorio.
# ─────────────────────────────────────────────────────────

# Base de datos — Neon PostgreSQL
# Obtenelo desde: https://neon.tech → tu proyecto → Connection string
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# NextAuth — Secret para firmar JWT
# Generalo con: openssl rand -base64 32
AUTH_SECRET="your-super-secret-here"

# NextAuth — URL del sitio (sin trailing slash)
# Desarrollo: http://localhost:3000
# Producción: https://tu-dominio.vercel.app
AUTH_URL="http://localhost:3000"
