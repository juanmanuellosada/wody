// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

enum Role {
  ADMIN
  TEACHER
  STUDENT
  ACCESS
}

enum GymKind {
  GYM
  BOX
  PERSONAL
}

enum StudentType {
  GENERAL
  PERSONALIZED
}

enum WodTargetType {
  ALL
  PERSONALIZED
  GROUP
  STUDENT
}

enum CouponRule {
  ONCE_PER_USER
  ONCE_PER_USER_PER_MONTH
  ONCE_GLOBAL
  UNLIMITED
}

enum RedemptionStatus {
  PENDING
  CONSUMED
}

enum AccessState {
  PENDING
  GRANTED
  DENIED
}

enum VerificationTokenType {
  INVITE
  RESET
}

enum EmailLogType {
  INVITE
  RESET
  QUOTA_ALERT_80
  QUOTA_ALERT_95
  JOIN_APPROVED
  PERSONAL_WELCOME
}

enum JoinRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum EmailLogStatus {
  SENT
  FAILED
}

model Gym {
  id                 String    @id @default(cuid())
  name               String
  slug               String    @unique
  kind               GymKind   @default(BOX)
  logo               String?
  primaryColor       String?
  createdAt          DateTime  @default(now())
  blockedAt          DateTime?
  autoBlockAfterDays Int       @default(45)
  nextMemberNumber   Int       @default(1)
  users              User[]
  accessLogs         AccessLog[]
  emailLogs          EmailLog[]
  joinRequests       JoinRequest[]
}

model User {
  id              String      @id @default(cuid())
  email           String
  password        String?
  name            String
  role            Role
  studentType     StudentType @default(PERSONALIZED)
  canCreateOwnRoutines Boolean @default(false)
  gymId           String
  createdAt       DateTime    @default(now())
  nextPaymentDate DateTime    @default(now()) @db.Date
  blockedAt       DateTime?
  deletedAt       DateTime?
  lastDueNotifiedOn DateTime? @db.Date
  memberNumber    Int
  emailVerifiedAt DateTime?

  gym   Gym    @relation(fields: [gymId], references: [id])

  wodsAsTeacher  Wod[]              @relation("TeacherWods")
  wodsTargetedTo Wod[]              @relation("WodTargetStudent")
  rms            RM[]
  teacherOf      TeacherStudent[]   @relation("TeacherRel")
  studentOf      TeacherStudent[]   @relation("StudentRel")
  teacherGroups  Group[]            @relation("TeacherGroups")
  groupMemberships GroupMember[]
  redemptions    CouponRedemption[]
  pushSubscriptions  PushSubscription[]
  accessesAsUser     AccessLog[] @relation("AccessLogUser")
  accessesDecidedBy  AccessLog[] @relation("AccessLogDecidedBy")
  verificationTokens VerificationToken[]
  joinRequestTeachers    JoinRequestTeacher[] @relation("JoinRequestTeacherToUser")
  joinRequestsReviewed   JoinRequest[] @relation("JoinRequestReviewer")
  // Unicidades parciales (solo filas activas, deletedAt IS NULL).
  // Los índices únicos totales fueron reemplazados por índices únicos parciales
  // de PostgreSQL en la migration add_user_soft_delete. Prisma no soporta WHERE
  // en @@unique, por eso se usan @@index no únicos aquí para mantener la
  // ergonomía de queries (findUnique por email_gymId / gymId_memberNumber).
  @@index([email, gymId])
  @@index([gymId, memberNumber])
  @@index([gymId, deletedAt])
}

model Group {
  id        String    @id @default(cuid())
  name      String
  teacherId String
  createdAt DateTime  @default(now())
  deletedAt DateTime?

  teacher  User          @relation("TeacherGroups", fields: [teacherId], references: [id], onDelete: Cascade)
  members  GroupMember[]
  wods     Wod[]         @relation("WodTargetGroup")

  // Unicidad parcial: solo entre grupos activos del mismo profe.
  // El índice único parcial vive en la migration add_user_soft_delete.
  @@index([teacherId, name])
}

model GroupMember {
  userId   String
  groupId  String

  user  User  @relation(fields: [userId],  references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([userId, groupId])
  @@index([groupId])
}

model Wod {
  id              String        @id @default(cuid())
  title           String        @default("WOD")
  content         String
  date            DateTime      @db.Date
  teacherId       String
  targetType      WodTargetType @default(ALL)
  targetGroupId   String?
  targetStudentId String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deletedAt       DateTime?

  teacher       User   @relation("TeacherWods", fields: [teacherId], references: [id], onDelete: Cascade)
  targetGroup   Group? @relation("WodTargetGroup", fields: [targetGroupId], references: [id], onDelete: SetNull)
  targetStudent User?  @relation("WodTargetStudent", fields: [targetStudentId], references: [id], onDelete: SetNull)

  @@index([teacherId, date(sort: Desc)])
}

model RM {
  id        String   @id @default(cuid())
  exercise  String
  weight    Float
  date      DateTime @db.Date
  studentId String
  createdAt DateTime @default(now())

  student User @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@map("PR")
}

model TeacherStudent {
  teacherId String
  studentId String

  teacher User @relation("TeacherRel", fields: [teacherId], references: [id], onDelete: Cascade)
  student User @relation("StudentRel", fields: [studentId], references: [id], onDelete: Cascade)

  @@id([teacherId, studentId])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AccessLog {
  id          String      @id @default(cuid())
  gymId       String
  userId      String
  at          DateTime    @default(now())
  state       AccessState @default(PENDING)
  decidedById String?
  decidedAt   DateTime?

  gym       Gym   @relation(fields: [gymId], references: [id], onDelete: Cascade)
  user      User  @relation("AccessLogUser", fields: [userId], references: [id], onDelete: Cascade)
  decidedBy User? @relation("AccessLogDecidedBy", fields: [decidedById], references: [id], onDelete: SetNull)

  @@index([gymId, state, at])
  @@index([gymId, at(sort: Desc)])
  @@index([userId])
}

model Coupon {
  id                   String     @id @default(cuid())
  slug                 String     @unique
  name                 String
  description          String
  instagramHandle      String
  instagramUrl         String
  logoKey              String?
  rule                 CouponRule
  active               Boolean    @default(true)
  sortOrder            Int        @default(0)
  requiresConsumedSlug String?
  hideWhenConsumed     Boolean    @default(false)
  expiresAt            DateTime?
  fixedCode            String?
  websiteUrl           String?
  restrictions         String?
  createdAt            DateTime   @default(now())

  redemptions CouponRedemption[]
}

model CouponRedemption {
  id         String           @id @default(cuid())
  code       String           @unique
  couponId   String
  userId     String
  status     RedemptionStatus @default(PENDING)
  createdAt  DateTime         @default(now())
  consumedAt DateTime?

  coupon Coupon @relation(fields: [couponId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, couponId])
  @@index([couponId, status])
}

model VerificationToken {
  id          String                @id @default(cuid())
  userId      String
  tokenHash   String                @unique
  type        VerificationTokenType
  expiresAt   DateTime
  consumedAt  DateTime?
  createdAt   DateTime              @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model JoinRequest {
  id              String            @id @default(cuid())
  gymId           String
  gym             Gym               @relation(fields: [gymId], references: [id], onDelete: Cascade)
  name            String
  email           String
  passwordHash    String
  nextPaymentDate DateTime          @db.Date
  status          JoinRequestStatus @default(PENDING)
  reviewedById    String?
  reviewedBy      User?             @relation("JoinRequestReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewedAt      DateTime?
  createdAt       DateTime          @default(now())

  teachers     JoinRequestTeacher[]

  @@index([gymId, status, createdAt])
}

model JoinRequestTeacher {
  joinRequestId String
  teacherId     String
  createdAt     DateTime @default(now())

  joinRequest JoinRequest @relation(fields: [joinRequestId], references: [id], onDelete: Cascade)
  teacher     User        @relation("JoinRequestTeacherToUser", fields: [teacherId], references: [id], onDelete: Cascade)

  @@id([joinRequestId, teacherId])
  @@index([teacherId])
}

model EmailLog {
  id           String         @id @default(cuid())
  gymId        String?
  to           String
  type         EmailLogType
  resendId     String?
  status       EmailLogStatus
  errorMessage String?
  sentAt       DateTime       @default(now())

  gym Gym? @relation(fields: [gymId], references: [id], onDelete: SetNull)

  @@index([sentAt, status])
  @@index([type, sentAt])
}

model PersonalAccessWhitelist {
  id          String    @id @default(cuid())
  email       String    @unique
  note        String?
  createdAt   DateTime  @default(now())
  consumedAt  DateTime?
}
