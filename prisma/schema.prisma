// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  TEACHER
  STUDENT
}

enum GymKind {
  GYM
  BOX
}

enum StudentType {
  GENERAL
  PERSONALIZED
}

enum WodTargetType {
  ALL
  PERSONALIZED
  GROUP
  STUDENT
}

enum CouponRule {
  ONCE_PER_USER
  ONCE_GLOBAL
  UNLIMITED
}

enum RedemptionStatus {
  PENDING
  CONSUMED
}

model Gym {
  id           String    @id @default(cuid())
  name         String
  slug         String    @unique
  kind         GymKind   @default(BOX)
  logo         String?
  primaryColor String?
  createdAt    DateTime  @default(now())
  blockedAt    DateTime?
  users        User[]
}

model User {
  id              String      @id @default(cuid())
  email           String
  password        String
  name            String
  role            Role
  studentType     StudentType @default(PERSONALIZED)
  gymId           String
  groupId         String?
  createdAt       DateTime    @default(now())
  nextPaymentDate DateTime    @default(now()) @db.Date
  blockedAt       DateTime?

  gym   Gym    @relation(fields: [gymId], references: [id])
  group Group? @relation("GroupStudents", fields: [groupId], references: [id], onDelete: SetNull)

  wodsAsTeacher  Wod[]              @relation("TeacherWods")
  wodsTargetedTo Wod[]              @relation("WodTargetStudent")
  rms            RM[]
  teacherOf      TeacherStudent[]   @relation("TeacherRel")
  studentOf      TeacherStudent[]   @relation("StudentRel")
  teacherGroups  Group[]            @relation("TeacherGroups")
  redemptions    CouponRedemption[]

  @@unique([email, gymId])
}

model Group {
  id        String   @id @default(cuid())
  name      String
  teacherId String
  createdAt DateTime @default(now())

  teacher  User   @relation("TeacherGroups", fields: [teacherId], references: [id], onDelete: Cascade)
  students User[] @relation("GroupStudents")
  wods     Wod[]  @relation("WodTargetGroup")

  @@unique([teacherId, name])
}

model Wod {
  id              String        @id @default(cuid())
  title           String        @default("WOD")
  content         String
  date            DateTime      @db.Date
  teacherId       String
  targetType      WodTargetType @default(ALL)
  targetGroupId   String?
  targetStudentId String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  teacher       User   @relation("TeacherWods", fields: [teacherId], references: [id], onDelete: Cascade)
  targetGroup   Group? @relation("WodTargetGroup", fields: [targetGroupId], references: [id], onDelete: SetNull)
  targetStudent User?  @relation("WodTargetStudent", fields: [targetStudentId], references: [id], onDelete: SetNull)

  @@index([teacherId, date(sort: Desc)])
}

model RM {
  id        String   @id @default(cuid())
  exercise  String
  weight    Float
  date      DateTime @db.Date
  studentId String
  createdAt DateTime @default(now())

  student User @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@map("PR")
}

model TeacherStudent {
  teacherId String
  studentId String

  teacher User @relation("TeacherRel", fields: [teacherId], references: [id], onDelete: Cascade)
  student User @relation("StudentRel", fields: [studentId], references: [id], onDelete: Cascade)

  @@id([teacherId, studentId])
}

model Coupon {
  id                   String     @id @default(cuid())
  slug                 String     @unique
  name                 String
  description          String
  instagramHandle      String
  instagramUrl         String
  logoKey              String?
  rule                 CouponRule
  active               Boolean    @default(true)
  sortOrder            Int        @default(0)
  requiresConsumedSlug String?
  hideWhenConsumed     Boolean    @default(false)
  expiresAt            DateTime?
  fixedCode            String?
  websiteUrl           String?
  restrictions         String?
  createdAt            DateTime   @default(now())

  redemptions CouponRedemption[]
}

model CouponRedemption {
  id         String           @id @default(cuid())
  code       String           @unique
  couponId   String
  userId     String
  status     RedemptionStatus @default(PENDING)
  createdAt  DateTime         @default(now())
  consumedAt DateTime?

  coupon Coupon @relation(fields: [couponId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, couponId])
  @@index([couponId, status])
}
